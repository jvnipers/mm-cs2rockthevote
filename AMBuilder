import os

for sdk_target in MMSPlugin.sdk_targets:
  sdk = sdk_target.sdk
  cxx = sdk_target.cxx

  binary = MMSPlugin.HL2Library(builder, cxx, f'{MMSPlugin.metadata["name"]}.{sdk["name"]}', sdk)

  binary.sources += [
    'src/cs2rockthevote.cpp',
    'src/config/config.cpp',
    'src/player/player_manager.cpp',
    'src/maplist/map_lister.cpp',
    'src/utils/print_utils.cpp',
    'src/utils/http_client.cpp',
    'src/timers/timer_system.cpp',
    'src/menu/chatmenu.cpp',
    'src/rtv/rtv_manager.cpp',
    'src/vote/map_vote.cpp',
    'src/nominate/nominate.cpp',
    'src/admin/admin_bridge.cpp',
  ]

  binary.custom = [builder.tools.Protoc(protoc = sdk_target.protoc, sources = [
    os.path.join(sdk['path'], 'common', 'network_connection.proto'),
    os.path.join(sdk['path'], 'common', 'networkbasetypes.proto'),
    os.path.join(sdk['path'], 'game', 'shared', 'usermessages.proto'),
  ])]

  nodes = builder.Add(binary)
  MMSPlugin.binaries += [nodes]
